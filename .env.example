LASTFM_API_KEY=
LASTFM_API_SECRET=
# Upstash Redis: habilita cache persistente, deduplicacao e fila entre instancias Vercel.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Intervalo global conservador entre chamadas feitas com a chave padrao.
LASTFM_MIN_INTERVAL_MS=1100
LASTFM_MAX_QUEUE_WAIT_MS=12000
# Opcional. Necessario apenas se o HTML ficar em outro dominio, como GitHub Pages.
ALLOWED_ORIGIN=
