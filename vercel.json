{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/", "destination": "/lastfm-collage.html" }
  ],
  "functions": {
    "api/lastfm.js": {
      "maxDuration": 30
    },
    "api/lastfm-auth.js": {
      "maxDuration": 30
    },
    "api/lastfm-write.js": {
      "maxDuration": 30
    },
    "api/lastfm-image.js": {
      "maxDuration": 30
    },
    "api/obsessions.js": {
      "maxDuration": 30
    },
    "api/deezer.js": {
      "maxDuration": 30
    },
    "api/fanart.js": {
      "maxDuration": 30
    },
    "api/fanart-image.js": {
      "maxDuration": 30
    },
    "api/youtube-music.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/lastfm-collage.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
